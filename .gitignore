# macOS
.DS_Store
.AppleDouble
.LSOverride

# Temporary files
*.tmp
*.temp
*.log
*.bak

# Editor directories and files
.vscode/
.idea/
*.swp
*.swo
*~

# OS thumbnails
**/__MACOSX/**
**/.DS_Store

# Build outputs (if any)
dist/
build/
coverage/

# Dependencies (if any)
node_modules/

# Environment and local config
.env                    # 忽略包含敏感信息的 .env 文件
.env.local
.env.*.local
!*.env.example          # 允许 .env.example 文件被添加（配置示例）

# Python cache (if any)
__pycache__/
.pytest_cache/
.mypy_cache/

# Generic caches
.cache/

# Local databases and exports
*.sqlite
*.sqlite3
*.db
