# ===========================================
# AtlasTradeAI 环境配置示例
# ===========================================

# ===========================================
# 数据库配置
# ===========================================
ATLAS_DB_PATH=data/atlas.db

# ===========================================
# 大模型配置（二选一）
# ===========================================

# 选项 1: 使用 OpenAI 大模型（默认）
# ATLAS_LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-your-openai-api-key
# OPENAI_BASE_URL=https://api.openai.com/v1/responses
# ATLAS_AGENT_MODEL=gpt-5-mini

# 选项 2: 使用智谱大模型（推荐）
ATLAS_LLM_PROVIDER=zhipu
ZHIPU_API_KEY=your-zhipu-api-key
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions
ATLAS_AGENT_MODEL=glm-4-air

# ===========================================
# 智谱模型选型说明
# ===========================================
# GLM-4-Flash  : 极速版，适合简单文档处理（¥0.0001/1K tokens）
# GLM-4-Air   : 平衡版，适合日常对话和建议生成（¥0.001/1K tokens）⭐ 推荐
# GLM-4-Plus  : 增强版，适合复杂分析和推理（¥0.05/1K tokens）
# GLM-4       : 旗舰版，适合专业任务（¥0.1/1K tokens）

# ===========================================
# Agent 运行模式配置
# ===========================================
# rules  : 纯规则模式，不使用大模型
# hybrid : 规则 + 大模型混合模式（推荐）
ATLAS_AGENT_MODE=hybrid

# ===========================================
# 钉钉集成配置
# ===========================================
# 运行模式：mock-api, webhook, openapi
DINGTALK_MODE=mock-api

# Webhook 模式配置
DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=xxx
DINGTALK_WEBHOOK_SECRET=xxx

# OpenAPI 模式配置
DINGTALK_CLIENT_ID=xxx
DINGTALK_CLIENT_SECRET=xxx
DINGTALK_ACCESS_TOKEN_URL=https://api.dingtalk.com/v1.0/oauth2/accessToken
DINGTALK_TODO_CREATE_URL=https://api.dingtalk.com/v1.0/todoTasks

# ===========================================
# 服务器配置
# ===========================================
HOST=0.0.0.0
PORT=8000
